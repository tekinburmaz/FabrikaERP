<Window x:Class="FabrikaERP.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FabrikaERP.Views"
        mc:Ignorable="d"
        Title="Fabrika ERP - Giriş" Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,20,0,40">
            <TextBlock Text="🏭 FABRİKA ERP" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Text="Sisteme Giriş Yapın" FontSize="14" Foreground="#AAAAAA" HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <TextBlock Text="Kullanıcı Adı" Foreground="White" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                     Height="35" Padding="5" FontSize="14" Background="#2D2D30" Foreground="White" BorderBrush="#555"/>

            <TextBlock Text="Şifre" Foreground="White" Margin="0,20,0,5"/>
            <PasswordBox x:Name="txtPassword" PasswordChanged="txtPassword_PasswordChanged"
                         Height="35" Padding="5" FontSize="14" Background="#2D2D30" Foreground="White" BorderBrush="#555"/>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF6B6B" Margin="0,15,0,0" Height="20" TextWrapping="Wrap"/>
        </StackPanel>

        <Button Grid.Row="2" Content="GİRİŞ YAP" Command="{Binding LoginCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}}"
                Height="45" FontSize="16" FontWeight="Bold" Background="#007ACC" Foreground="White" Cursor="Hand" Margin="0,0,0,20">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>
