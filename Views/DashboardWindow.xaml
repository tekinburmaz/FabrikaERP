<Window x:Class="FabrikaERP.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FabrikaERP — Üretim Yönetim Sistemi"
        Height="800" Width="1280"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local_conv:TransactionColorConverter x:Key="TransactionColorConverter" xmlns:local_conv="clr-namespace:FabrikaERP.Views.Converters"/>

        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#8B949E"/>
            <Setter Property="Height"          Value="44"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="8,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#161B22"/>
                                <Setter Property="Foreground" Value="#C9D1D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WinBtn" TargetType="Button">
            <Setter Property="Width"  Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#21262D"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WinCloseBtn" TargetType="Button" BasedOn="{StaticResource WinBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F85149"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" ClipToBounds="True" Background="#0D1117">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="#000000" Opacity="0.7"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ SIDEBAR ═══ -->
            <Border Grid.Column="0" Background="#0B0F14"
                    BorderBrush="#21262D" BorderThickness="0,0,1,0">
                <DockPanel>

                    <!-- Logo -->
                    <Border DockPanel.Dock="Top" Padding="20,18,20,14"
                            BorderBrush="#21262D" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <Canvas Width="26" Height="26" Margin="0,0,10,0">
                                <Rectangle Canvas.Left="2" Canvas.Top="9"  Width="22" Height="17" Fill="#58A6FF" RadiusX="2" RadiusY="2"/>
                                <Polygon Points="0,9 13,0 26,9" Fill="#1F6FEB" Canvas.Left="2"/>
                                <Rectangle Canvas.Left="18" Canvas.Top="3" Width="5"  Height="8"  Fill="#30363D"/>
                            </Canvas>
                            <TextBlock Text="FabrikaERP" FontSize="16" FontWeight="Bold"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Çıkış -->
                    <Border DockPanel.Dock="Bottom" Padding="8,10"
                            BorderBrush="#21262D" BorderThickness="0,1,0,0">
                        <Button Style="{StaticResource NavBtn}" Command="{Binding LogoutCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2190;" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Çıkış Yap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Menü -->
                    <ScrollViewer VerticalScrollBarVisibility="Hidden">
                        <StackPanel Margin="0,10,0,0">

                             <!-- ── GENEL ── -->
                            <TextBlock Text="GENEL" FontSize="10" FontWeight="SemiBold" Foreground="#484F58" Margin="24,0,0,6"/>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateDashboard}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4CA;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- ── ÜRETİM & AR-GE ── -->
                            <TextBlock Text="ÜRETİM &amp; AR-GE" FontSize="10" FontWeight="SemiBold" Foreground="#484F58" Margin="24,14,0,6"/>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateShopFloor}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F3ED;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Üretim Hattı" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateMES}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x2699;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="MES / İş Emirleri" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateMRP}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4CB;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="MRP Planlama" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateRnD}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F52C;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Ar-Ge Yönetimi" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateProdDev}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F3A8;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Ürün Geliştirme" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigatePlm}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F504;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Ürün Yaşam (PLM)" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- ── PLANLAMA ── -->
                            <TextBlock Text="PLANLAMA" FontSize="10" FontWeight="SemiBold" Foreground="#484F58" Margin="24,14,0,6"/>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateForecast}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F52E;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Talep Tahmini" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateMPS}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4C5;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Ana Planlama (MPS)" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigatePlanning}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4C8;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Kapasite Planlama" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- ── KALİTE & İSG ── -->
                            <TextBlock Text="KALİTE &amp; İSG" FontSize="10" FontWeight="SemiBold" Foreground="#484F58" Margin="24,14,0,6"/>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateQuality}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x2714;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Hat Sonu Kalite" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateQualityMgmt}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4DC;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Kalite Sist. (QMS)" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateSafetyEnv}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F6E1;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="İSG &amp; Çevre" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateCompliance}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x2696;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Yasal Uyumluluk" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- ── LOJİSTİK ── -->
                            <TextBlock Text="LOJİSTİK" FontSize="10" FontWeight="SemiBold" Foreground="#484F58" Margin="24,14,0,6"/>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateInventory}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4E6;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Depo Yönetimi (WMS)" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateProdLogistics}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F69A;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Üretim Lojistiği" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateDistribution}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4E6;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Sevkiyat &amp; Dağıtım" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- ── TİCARİ ── -->
                            <TextBlock Text="TİCARİ" FontSize="10" FontWeight="SemiBold" Foreground="#484F58" Margin="24,14,0,6"/>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateSalesOrder}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F6D2;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Sipariş Yönetimi" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateTrade}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F91D;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="CRM &amp; SRM" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateSalesAnalytics}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4C8;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Satış Analizi" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- ── FİNANS ── -->
                            <TextBlock Text="FİNANS" FontSize="10" FontWeight="SemiBold" Foreground="#484F58" Margin="24,14,0,6"/>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateFinance}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4B0;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Finans Yönetimi" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateGL}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4D3;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Genel Muhasebe" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateCost}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4D0;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Maliyet Yönetimi" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateBudget}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4DD;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Bütçe &amp; Tahmin" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- ── KURUMSAL ── -->
                            <TextBlock Text="KURUMSAL" FontSize="10" FontWeight="SemiBold" Foreground="#484F58" Margin="24,14,0,6"/>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateHR}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F465;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="İK / Personel" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigatePayroll}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4B3;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Bordro &amp; Özlük" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateWorkforce}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F3AF;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="İş Gücü Matrisi" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- ── SİSTEM ── -->
                            <TextBlock Text="SİSTEM" FontSize="10" FontWeight="SemiBold" Foreground="#484F58" Margin="24,14,0,6"/>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateMaintenance}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F527;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Makine Bakım" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateEnergy}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x26A1;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Enerji Yönetimi" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateOEE}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F3C1;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="OEE Analizi" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateAudit}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F50D;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Denetim &amp; Log" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateDocs}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4C4;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Doküman Yönetimi" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Command="{Binding NavigateSettings}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x2699;" FontSize="14" Margin="0,0,10,0"/><TextBlock Text="Sistem Ayarları" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ═══ ANA İÇERİK ═══ -->
            <DockPanel Grid.Column="1">

                <!-- Üst bar -->
                <Border DockPanel.Dock="Top" Background="#0D1117"
                        BorderBrush="#21262D" BorderThickness="0,0,0,1" Height="56">
                    <Grid Margin="20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding PageTitle}"
                                       FontSize="16" FontWeight="SemiBold" Foreground="#C9D1D9"/>
                            <TextBlock Text="{Binding Breadcrumb}"
                                       FontSize="11" Foreground="#484F58" Margin="0,2,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Background="#1A0A0A" BorderBrush="#F85149"
                                    BorderThickness="1" CornerRadius="14"
                                    Padding="10,3" Margin="0,0,8,0" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x26A0;" Foreground="#F85149" FontSize="12"/>
                                    <TextBlock Text="{Binding ActiveAlerts}" Foreground="#F85149"
                                               FontSize="12" FontWeight="SemiBold" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Border>
                            <Ellipse Width="30" Height="30" Margin="0,0,6,0">
                                <Ellipse.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1F6FEB" Offset="0"/>
                                        <GradientStop Color="#00D4FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="{Binding UserName}"
                                           FontSize="13" FontWeight="SemiBold" Foreground="#C9D1D9"/>
                                <TextBlock Text="Aktif" FontSize="10" Foreground="#3FB950"/>
                            </StackPanel>
                            <Button Style="{StaticResource WinBtn}"      Content="—"        Click="BtnMinimize_Click"/>
                            <Button Style="{StaticResource WinBtn}"      Content="&#x2750;" Click="BtnMaximize_Click"/>
                            <Button Style="{StaticResource WinCloseBtn}" Content="✕"        Click="BtnClose_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Sayfa içeriği -->
                <ContentControl x:Name="MainContent" Background="#0D1117"/>
            </DockPanel>
        </Grid>
    </Border>
</Window>
