<UserControl x:Class="FabrikaERP.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0D1117">

    <UserControl.Resources>
        <Style x:Key="SettingCard" TargetType="Border">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24,20"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#21262D"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#58A6FF"/>
        </Style>
        <Style x:Key="PwdBox" TargetType="PasswordBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,24,24,32">

            <!-- Başlık -->
            <StackPanel Margin="0,0,0,24">
                <TextBlock Text="Ayarlar" FontSize="16" FontWeight="SemiBold" Foreground="#C9D1D9"/>
                <TextBlock Text="Uygulama ve kullanıcı tercihlerini yönetin" FontSize="12" Foreground="#8B949E" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Durum Mesajı -->
            <Border CornerRadius="8" Padding="14,10" Margin="0,0,0,16"
                    Visibility="{Binding HasStatus, Converter={StaticResource BoolVis}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#0C2A14"/>
                        <Setter Property="BorderBrush" Value="#3FB950"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsStatusSuccess}" Value="False">
                                <Setter Property="Background" Value="#2D0E0E"/>
                                <Setter Property="BorderBrush" Value="#F85149"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding StatusMessage}" FontSize="13">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#3FB950"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStatusSuccess}" Value="False">
                                    <Setter Property="Foreground" Value="#F85149"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <!-- 2 sütun layout -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Sol sütun: Profil -->
                <Border Grid.Column="0" Grid.Row="0" Style="{StaticResource SettingCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="&#x1F464;" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Profil Bilgileri" Style="{StaticResource SectionTitle}" Margin="0"/>
                        </StackPanel>

                        <!-- Avatar -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="56" Height="56" CornerRadius="28"
                                    Background="#1F6FEB" Margin="0,0,16,0">
                                <TextBlock Text="{Binding AvatarInitial}"
                                           FontSize="22" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold" Foreground="#C9D1D9"/>
                                <TextBlock Text="{Binding Role}" FontSize="12" Foreground="#8B949E" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Ad Soyad"/>
                        <TextBox Style="{StaticResource InputBox}" Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="E-posta"/>
                        <TextBox Style="{StaticResource InputBox}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Rol"/>
                        <TextBox Style="{StaticResource InputBox}" Text="{Binding Role}" IsReadOnly="True"
                                 Foreground="#8B949E" Margin="0,0,0,20"/>

                        <Button Content="Profili Kaydet" Command="{Binding SaveProfileCommand}"
                                Background="#1F6FEB" Style="{StaticResource ActionBtn}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Sağ sütun: Şifre -->
                <Border Grid.Column="2" Grid.Row="0" Style="{StaticResource SettingCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="&#x1F512;" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Şifre Değiştir" Style="{StaticResource SectionTitle}" Margin="0"/>
                        </StackPanel>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Mevcut Şifre"/>
                        <PasswordBox Style="{StaticResource PwdBox}" Margin="0,0,0,12"
                                     x:Name="TxtCurrentPwd"/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Yeni Şifre"/>
                        <PasswordBox Style="{StaticResource PwdBox}" Margin="0,0,0,12"
                                     x:Name="TxtNewPwd"/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Yeni Şifre (Tekrar)"/>
                        <PasswordBox Style="{StaticResource PwdBox}" Margin="0,0,0,20"
                                     x:Name="TxtConfirmPwd"/>

                        <Button Content="Şifreyi Değiştir" Command="{Binding ChangePasswordCommand}"
                                Background="#3FB950" Style="{StaticResource ActionBtn}" HorizontalAlignment="Left"
                                Click="PasswordBtn_Click"/>

                        <Border Background="#161B22" BorderBrush="#21262D" BorderThickness="1"
                                CornerRadius="8" Padding="12" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Şifre Gereksinimleri" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#8B949E" Margin="0,0,0,6"/>
                                <TextBlock Text="• En az 6 karakter" FontSize="11" Foreground="#6E7681"/>
                                <TextBlock Text="• Büyük/küçük harf karışık önerilir" FontSize="11" Foreground="#6E7681"/>
                                <TextBlock Text="• Özel karakter kullanımı güvenliği artırır" FontSize="11" Foreground="#6E7681"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Sol alt: Görünüm & Dil -->
                <Border Grid.Column="0" Grid.Row="1" Style="{StaticResource SettingCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="&#x1F3A8;" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Görünüm &amp; Dil" Style="{StaticResource SectionTitle}" Margin="0"/>
                        </StackPanel>

                        <!-- Karanlık Tema Toggle -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Karanlık Tema" FontSize="13" Foreground="#C9D1D9"/>
                                <TextBlock Text="GitHub Dark renk paleti" FontSize="11" Foreground="#6E7681" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding IsDarkTheme}" VerticalAlignment="Center"/>
                        </Grid>

                        <Separator Background="#21262D" Margin="0,4,0,14"/>

                        <!-- Bildirimler Toggle -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Bildirimler" FontSize="13" Foreground="#C9D1D9"/>
                                <TextBlock Text="Kritik uyarılar ve alarm bildirimleri" FontSize="11" Foreground="#6E7681" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding ShowNotifications}" VerticalAlignment="Center"/>
                        </Grid>

                        <Separator Background="#21262D" Margin="0,4,0,14"/>

                        <!-- Dil -->
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Arayüz Dili"/>
                        <ComboBox ItemsSource="{Binding LanguageOptions}"
                                  SelectedItem="{Binding SelectedLanguage}"
                                  Height="36" Background="#0D1117" Foreground="#C9D1D9"
                                  BorderBrush="#30363D" FontSize="13" Margin="0,0,0,20"/>

                        <Button Content="Ayarları Kaydet" Command="{Binding SaveAppSettingsCommand}"
                                Background="#6E40C9" Style="{StaticResource ActionBtn}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Sağ alt: Veritabanı & Sistem -->
                <Border Grid.Column="2" Grid.Row="1" Style="{StaticResource SettingCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="&#x1F5C4;" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Veritabanı &amp; Sistem" Style="{StaticResource SectionTitle}" Margin="0"/>
                        </StackPanel>

                        <!-- DB Durum -->
                        <Border Background="#0D1117" BorderBrush="#21262D" BorderThickness="1"
                                CornerRadius="8" Padding="14,12" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="SQLite Bağlantısı" FontSize="12" FontWeight="SemiBold" Foreground="#C9D1D9"/>
                                    <TextBlock Text="{Binding DbPath}" FontSize="10" Foreground="#6E7681"
                                               TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" CornerRadius="10" Padding="8,3" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#0C2A14"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDbConnected}" Value="False">
                                                    <Setter Property="Background" Value="#2D0E0E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding DbStatus}" FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#3FB950"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDbConnected}" Value="False">
                                                        <Setter Property="Foreground" Value="#F85149"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- DB Aksiyonlar -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Button Content="Bağlantıyı Test Et" Command="{Binding TestDbCommand}"
                                    Background="#21262D" Foreground="#C9D1D9"
                                    Style="{StaticResource ActionBtn}" Margin="0,0,8,0"/>
                            <Button Content="Yedek Al" Command="{Binding BackupDbCommand}"
                                    Background="#21262D" Foreground="#C9D1D9"
                                    Style="{StaticResource ActionBtn}"/>
                        </StackPanel>

                        <Separator Background="#21262D" Margin="0,0,0,16"/>

                        <!-- Sistem Bilgisi -->
                        <TextBlock Text="Sistem Bilgisi" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#8B949E" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Versiyon" FontSize="12" Foreground="#6E7681"/>
                            <TextBlock Grid.Column="1" Text="{Binding AppVersion}" FontSize="12" Foreground="#C9D1D9"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text=".NET" FontSize="12" Foreground="#6E7681"/>
                            <TextBlock Grid.Column="1" Text="{Binding DotNetVersion}" FontSize="12" Foreground="#C9D1D9"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Yapım Tarihi" FontSize="12" Foreground="#6E7681"/>
                            <TextBlock Grid.Column="1" Text="{Binding BuildDate}" FontSize="12" Foreground="#C9D1D9"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
