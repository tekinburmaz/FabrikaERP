<UserControl x:Class="FabrikaERP.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0D1117">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="KpiCard" TargetType="Border">
            <Setter Property="Background"      Value="#161B22"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="20,18"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#21262D"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="14"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="#C9D1D9"/>
            <Setter Property="Margin"       Value="0,0,0,14"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24,24,24,32">

            <!-- ── Sistem durumu şeridi ── -->
            <Border Background="#0C1A0E" BorderBrush="#3FB950" BorderThickness="1"
                    CornerRadius="8" Padding="16,10" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="#3FB950" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Foreground="#3FB950" FontSize="13" FontWeight="SemiBold" Text="Sistem Çevrimiçi"/>
                    <TextBlock Foreground="#8B949E" FontSize="12" Margin="12,0,0,0" VerticalAlignment="Center"
                               Text="Son senkronizasyon: bugün 08:43 — Tüm modüller aktif"/>
                    <TextBlock Text="{Binding ProductionRate, StringFormat='  |  Üretim: {0} adet/saat'}"
                               Foreground="#58A6FF" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ── KPI Kartları ── -->
            <TextBlock Text="Bugünün Özeti" Style="{StaticResource SectionTitle}"/>
            <UniformGrid Columns="4" Margin="0,0,0,24">

                <!-- Üretim Hızı -->
                <Border Style="{StaticResource KpiCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="&#x1F3ED;" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Üretim Hızı" Foreground="#8B949E" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ProductionRate, StringFormat='{}{0:N0}'}"
                                   FontSize="32" FontWeight="Bold" Foreground="#C9D1D9"/>
                        <TextBlock Text="adet / saat" Foreground="#8B949E" FontSize="12" Margin="0,2,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▲ 12.4%" Foreground="#3FB950" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text=" geçen haftaya göre" Foreground="#8B949E" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- OEE -->
                <Border Style="{StaticResource KpiCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="&#x2699;" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="OEE" Foreground="#8B949E" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding OeePercent, StringFormat='{}{0:F1}%'}"
                                   FontSize="32" FontWeight="Bold" Foreground="#58A6FF"/>
                        <TextBlock Text="Overall Equipment Effectiveness" Foreground="#8B949E" FontSize="12" Margin="0,2,0,10"/>
                        <ProgressBar Value="{Binding OeePercent}" Maximum="100" Height="4"
                                     Background="#21262D" Foreground="#58A6FF" BorderThickness="0"/>
                    </StackPanel>
                </Border>

                <!-- Kalite -->
                <Border Style="{StaticResource KpiCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="&#x2714;" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Kalite Oranı" Foreground="#8B949E" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding QualityRate, StringFormat='{}{0:F1}%'}"
                                   FontSize="32" FontWeight="Bold" Foreground="#3FB950"/>
                        <TextBlock Text="geçen ürünler / toplam" Foreground="#8B949E" FontSize="12" Margin="0,2,0,10"/>
                        <ProgressBar Value="{Binding QualityRate}" Maximum="100" Height="4"
                                     Background="#21262D" Foreground="#3FB950" BorderThickness="0"/>
                    </StackPanel>
                </Border>

                <!-- Aktif Makine -->
                <Border Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="&#x26A1;" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Aktif Makine" Foreground="#8B949E" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding ActiveMachines}"
                                       FontSize="32" FontWeight="Bold" Foreground="#C9D1D9"/>
                            <TextBlock Text="{Binding TotalMachines, StringFormat=' / {0}'}"
                                       FontSize="20" Foreground="#8B949E" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                        </StackPanel>
                        <TextBlock Text="makine çalışıyor" Foreground="#8B949E" FontSize="12" Margin="0,2,0,10"/>
                        <ProgressBar Value="{Binding ActiveMachines}" Maximum="{Binding TotalMachines}" Height="4"
                                     Background="#21262D" Foreground="#D29922" BorderThickness="0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ── Orta Satır: Grafik + Uyarılar ── -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- Üretim Bar Grafiği -->
                <Border Grid.Column="0" Background="#161B22" CornerRadius="12"
                        Padding="20,18" BorderThickness="1" BorderBrush="#21262D" Margin="0,0,16,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="Günlük Üretim Trendi" FontSize="14" FontWeight="SemiBold" Foreground="#C9D1D9"/>
                            <Border Background="#0C2A14" BorderBrush="#3FB950" BorderThickness="1"
                                    CornerRadius="10" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Canlı" Foreground="#3FB950" FontSize="11"/>
                            </Border>
                        </StackPanel>

                        <!-- Y ekseni etiketleri + çubuklar -->
                        <Grid Height="200">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Y etiketleri -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Stretch">
                                <TextBlock Text="1500" Foreground="#484F58" FontSize="9" VerticalAlignment="Top"/>
                                <TextBlock Text="1200" Foreground="#484F58" FontSize="9" VerticalAlignment="Center" Margin="0,30"/>
                                <TextBlock Text="900"  Foreground="#484F58" FontSize="9" VerticalAlignment="Center"/>
                                <TextBlock Text="600"  Foreground="#484F58" FontSize="9" VerticalAlignment="Bottom" Margin="0,30"/>
                            </StackPanel>

                            <!-- Grafik alanı -->
                            <Canvas Grid.Column="1" x:Name="ChartCanvas" Height="180" VerticalAlignment="Bottom">
                                <!-- Yatay çizgiler -->
                                <Line X1="0" Y1="0"   X2="700" Y2="0"   Stroke="#21262D" StrokeThickness="1"/>
                                <Line X1="0" Y1="45"  X2="700" Y2="45"  Stroke="#21262D" StrokeThickness="1"/>
                                <Line X1="0" Y1="90"  X2="700" Y2="90"  Stroke="#21262D" StrokeThickness="1"/>
                                <Line X1="0" Y1="135" X2="700" Y2="135" Stroke="#21262D" StrokeThickness="1"/>
                                <Line X1="0" Y1="180" X2="700" Y2="180" Stroke="#21262D" StrokeThickness="1"/>

                                <!-- Çubuklar (8 saat, saatlik üretim) -->
                                <Rectangle Canvas.Left="10"  Canvas.Bottom="0" Width="54" Height="112" Fill="#1F6FEB" Opacity="0.85" RadiusX="4" RadiusY="4"/>
                                <Rectangle Canvas.Left="90"  Canvas.Bottom="0" Width="54" Height="134" Fill="#1F6FEB" Opacity="0.85" RadiusX="4" RadiusY="4"/>
                                <Rectangle Canvas.Left="170" Canvas.Bottom="0" Width="54" Height="122" Fill="#1F6FEB" Opacity="0.85" RadiusX="4" RadiusY="4"/>
                                <Rectangle Canvas.Left="250" Canvas.Bottom="0" Width="54" Height="158" Fill="#58A6FF" Opacity="0.90" RadiusX="4" RadiusY="4"/>
                                <Rectangle Canvas.Left="330" Canvas.Bottom="0" Width="54" Height="144" Fill="#1F6FEB" Opacity="0.85" RadiusX="4" RadiusY="4"/>
                                <Rectangle Canvas.Left="410" Canvas.Bottom="0" Width="54" Height="170" Fill="#00D4FF" Opacity="0.90" RadiusX="4" RadiusY="4"/>
                                <Rectangle Canvas.Left="490" Canvas.Bottom="0" Width="54" Height="138" Fill="#1F6FEB" Opacity="0.85" RadiusX="4" RadiusY="4"/>
                                <Rectangle Canvas.Left="570" Canvas.Bottom="0" Width="54" Height="126" Fill="#1F6FEB" Opacity="0.85" RadiusX="4" RadiusY="4"/>

                                <!-- Saat etiketleri -->
                                <TextBlock Canvas.Left="18"  Canvas.Top="185" Text="08:00" Foreground="#484F58" FontSize="10"/>
                                <TextBlock Canvas.Left="98"  Canvas.Top="185" Text="09:00" Foreground="#484F58" FontSize="10"/>
                                <TextBlock Canvas.Left="178" Canvas.Top="185" Text="10:00" Foreground="#484F58" FontSize="10"/>
                                <TextBlock Canvas.Left="258" Canvas.Top="185" Text="11:00" Foreground="#484F58" FontSize="10"/>
                                <TextBlock Canvas.Left="338" Canvas.Top="185" Text="12:00" Foreground="#484F58" FontSize="10"/>
                                <TextBlock Canvas.Left="418" Canvas.Top="185" Text="13:00" Foreground="#484F58" FontSize="10"/>
                                <TextBlock Canvas.Left="498" Canvas.Top="185" Text="14:00" Foreground="#484F58" FontSize="10"/>
                                <TextBlock Canvas.Left="578" Canvas.Top="185" Text="15:00" Foreground="#484F58" FontSize="10"/>
                            </Canvas>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Uyarılar paneli -->
                <Border Grid.Column="1" Background="#161B22" CornerRadius="12"
                        Padding="18,18" BorderThickness="1" BorderBrush="#21262D">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Aktif Uyarılar"
                                   FontSize="14" FontWeight="SemiBold" Foreground="#C9D1D9" Margin="0,0,0,14"/>
                        <ItemsControl ItemsSource="{Binding ActiveAlertList}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" CornerRadius="8" Padding="12,10">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#0C1A28"/>
                                                <Setter Property="BorderBrush" Value="#58A6FF"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,0"/>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Severity}" Foreground="#8B949E"
                                                       FontSize="10" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Title}" Foreground="#C9D1D9"
                                                       FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- ── Son İş Emirleri ── -->
            <Border Background="#161B22" CornerRadius="12"
                    Padding="0" BorderThickness="1" BorderBrush="#21262D">
                <StackPanel>
                    <!-- Tablo başlık -->
                    <StackPanel Orientation="Horizontal" Margin="20,18,20,14">
                        <TextBlock Text="Son İş Emirleri" FontSize="14" FontWeight="SemiBold" Foreground="#C9D1D9"/>
                        <Border Background="#21262D" CornerRadius="10" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding RecentWorkOrders.Count, StringFormat='{}{0} kayıt'}"
                                       Foreground="#8B949E" FontSize="11"/>
                        </Border>
                    </StackPanel>

                    <!-- Sütun başlıkları -->
                    <Border Background="#21262D" Padding="20,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="İŞ EMRİ NO"  Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="ÜRÜN"         Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="PLN.MİKTAR"  Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="ÜRETİLEN"    Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="4" Text="TESLİM"      Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="5" Text="DURUM"       Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                        </Grid>
                    </Border>

                    <!-- Satırlar -->
                    <ItemsControl ItemsSource="{Binding RecentWorkOrders}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#21262D" BorderThickness="0,0,0,1" Padding="20,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="110"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding OrderNumber}"
                                                   Foreground="#58A6FF" FontSize="12" FontFamily="Consolas"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ProductName}"
                                                   Foreground="#C9D1D9" FontSize="13"/>
                                        <TextBlock Grid.Column="2" Text="{Binding PlannedQty}"
                                                   Foreground="#C9D1D9" FontSize="13"/>
                                        <TextBlock Grid.Column="3" Text="{Binding ProducedQty}"
                                                   Foreground="#C9D1D9" FontSize="13"/>
                                        <TextBlock Grid.Column="4" Text="{Binding PlannedEnd, StringFormat='{}{0:dd MMM yyyy}'}"
                                                   Foreground="#8B949E" FontSize="13"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Status}"
                                                   Foreground="#3FB950" FontSize="12"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
