<UserControl x:Class="FabrikaERP.Views.Pages.InventoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0D1117">

    <UserControl.Resources>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#21262D"/>
        </Style>
        <Style x:Key="FilterBox" TargetType="TextBox">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#58A6FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,24,24,32">

            <!-- ── KPI Kartları ── -->
            <UniformGrid Columns="3" Margin="0,0,0,24">
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Toplam Stok Kalemi" Foreground="#8B949E" FontSize="12"/>
                        <TextBlock Text="{Binding TotalItemCount}" FontSize="32" FontWeight="Bold" Foreground="#C9D1D9" Margin="0,6,0,0"/>
                        <TextBlock Text="farklı kalem" Foreground="#8B949E" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Kritik Stok" Foreground="#8B949E" FontSize="12"/>
                        <TextBlock Text="{Binding LowStockCount}" FontSize="32" FontWeight="Bold" Foreground="#F85149" Margin="0,6,0,0"/>
                        <TextBlock Text="kalem minimum altında" Foreground="#8B949E" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="Toplam Stok Değeri" Foreground="#8B949E" FontSize="12"/>
                        <TextBlock Text="{Binding TotalValue, StringFormat='₺ {0:N0}'}" FontSize="28" FontWeight="Bold" Foreground="#58A6FF" Margin="0,6,0,0"/>
                        <TextBlock Text="TL" Foreground="#8B949E" FontSize="12"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ── Kritik Stok Uyarıları ── -->
            <Border Background="#1A0808" BorderBrush="#F85149" BorderThickness="1" CornerRadius="10"
                    Padding="16,14" Margin="0,0,0,24">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="&#x26A0;" Foreground="#F85149" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="Kritik Stok Kalemleri" Foreground="#F85149"
                                   FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding LowStockItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2A0808" BorderBrush="#F85149" BorderThickness="1"
                                        CornerRadius="8" Padding="10,6" Margin="0,0,8,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Code}" Foreground="#F85149"
                                                   FontSize="11" FontFamily="Consolas" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding Name}" Foreground="#C9D1D9" FontSize="12"/>
                                        <TextBlock Text="{Binding StockQty, StringFormat=' — {0}'}"
                                                   Foreground="#F85149" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Unit, StringFormat=' {0}'}"
                                                   Foreground="#8B949E" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ── Filtre ── -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Style="{StaticResource FilterBox}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,12,0"/>
                <Button Grid.Column="1" Content="Yenile" Command="{Binding RefreshCommand}"
                        Height="36" Padding="16,0" Background="#21262D" Foreground="#C9D1D9"
                        BorderBrush="#30363D" BorderThickness="1" FontSize="13" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#2D333B"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- ── Stok Tablosu ── -->
            <Border Background="#161B22" CornerRadius="12"
                    BorderThickness="1" BorderBrush="#21262D">
                <StackPanel>
                    <Border Background="#21262D" CornerRadius="12,12,0,0" Padding="20,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="KOD"       Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="AD"        Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="KATEGORİ"  Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="STOK"      Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="4" Text="MİN."      Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="5" Text="BİRİM"     Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="6" Text="BİRİM FİYAT" Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="7" Text="DURUM"     Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                        </Grid>
                    </Border>
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#21262D" BorderThickness="0,0,0,1" Padding="20,11">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Code}"
                                                   Foreground="#58A6FF" FontSize="12" FontFamily="Consolas"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   Foreground="#C9D1D9" FontSize="13"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Category}"
                                                   Foreground="#8B949E" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="{Binding StockQty}"
                                                   FontSize="13" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#C9D1D9"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                                            <Setter Property="Foreground" Value="#F85149"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Grid.Column="4" Text="{Binding MinStock}"
                                                   Foreground="#8B949E" FontSize="13"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Unit}"
                                                   Foreground="#8B949E" FontSize="12"/>
                                        <TextBlock Grid.Column="6" Text="{Binding UnitCost, StringFormat='₺ {0:N2}'}"
                                                   Foreground="#C9D1D9" FontSize="13"/>
                                        <!-- Durum badge -->
                                        <Border Grid.Column="7" CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#0C2A14"/>
                                                    <Setter Property="BorderBrush" Value="#3FB950"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                                            <Setter Property="Background" Value="#2A0A0A"/>
                                                            <Setter Property="BorderBrush" Value="#F85149"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Normal"/>
                                                        <Setter Property="Foreground" Value="#3FB950"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                                                <Setter Property="Text" Value="Kritik"/>
                                                                <Setter Property="Foreground" Value="#F85149"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
