<UserControl x:Class="FabrikaERP.Views.Pages.GenericModulePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="800" Background="#0D1117">
    <Grid Margin="40">
        <Border Background="#161B22" CornerRadius="12" Padding="40" BorderBrush="#30363D" BorderThickness="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="TxtIcon" Text="⚙️" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock x:Name="TxtTitle" Text="Modül Başlığı" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtDescription" Text="Bu modülün temel altyapısı ve veri modelleri hazırlanmıştır. Detaylı fonksiyonlar için geliştirme süreci devam etmektedir." 
                           Foreground="#8B949E" FontSize="16" TextAlignment="Center" TextWrapping="Wrap" Margin="0,20,0,0"/>
                
                <Separator Background="#30363D" Margin="0,30"/>
                
                <UniformGrid Columns="3">
                    <StackPanel Margin="10">
                        <TextBlock Text="Durum" Foreground="#484F58" FontSize="12"/>
                        <TextBlock Text="Aktif İskelet" Foreground="#3FB950" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Margin="10">
                        <TextBlock Text="Veri Tabanı" Foreground="#484F58" FontSize="12"/>
                        <TextBlock Text="Bağlı" Foreground="#58A6FF" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Margin="10">
                        <TextBlock Text="Versiyon" Foreground="#484F58" FontSize="12"/>
                        <TextBlock Text="v1.0-Shell" Foreground="White" FontWeight="SemiBold"/>
                    </StackPanel>
                </UniformGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
