<UserControl x:Class="FabrikaERP.Views.Pages.ReportsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0D1117">

    <UserControl.Resources>
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,18"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#21262D"/>
        </Style>
        <Style x:Key="ExportBtn" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,24,24,32">

            <!-- Üst araç çubuğu -->
            <Grid Margin="0,0,0,24">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Yönetim Raporları" FontSize="16" FontWeight="SemiBold" Foreground="#C9D1D9"/>
                    <TextBlock Text="Tüm modüllerin özet performans verileri" FontSize="12" Foreground="#8B949E" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <ComboBox ItemsSource="{Binding PeriodOptions}"
                              SelectedItem="{Binding SelectedPeriod}"
                              Width="140" Height="36" Margin="0,0,8,0"
                              Background="#161B22" Foreground="#C9D1D9"
                              BorderBrush="#30363D" FontSize="13"/>
                    <Button Content="PDF İndir" Command="{Binding ExportPdfCommand}"
                            Background="#1A0A0A" Foreground="#F85149"
                            BorderBrush="#F85149"
                            Style="{StaticResource ExportBtn}" Margin="0,0,8,0"/>
                    <Button Content="Excel İndir" Command="{Binding ExportXlsCommand}"
                            Background="#0C2A14" Foreground="#3FB950"
                            BorderBrush="#3FB950"
                            Style="{StaticResource ExportBtn}"/>
                </StackPanel>
            </Grid>

            <!-- 2x2 Rapor Bölümleri -->
            <UniformGrid Columns="2">

                <!-- Üretim -->
                <Border Style="{StaticResource SectionCard}" Margin="0,0,12,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="&#x1F3ED;" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Üretim" FontSize="14" FontWeight="SemiBold" Foreground="#C9D1D9"/>
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding ProductionSummary}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="#8B949E" FontSize="13"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}"
                                                   Foreground="#C9D1D9" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Change}"
                                                   HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#3FB950"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUp}" Value="False">
                                                            <Setter Property="Foreground" Value="#F85149"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Kalite -->
                <Border Style="{StaticResource SectionCard}" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="&#x2714;" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Kalite Kontrol" FontSize="14" FontWeight="SemiBold" Foreground="#C9D1D9"/>
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding QualitySummary}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="#8B949E" FontSize="13"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="#C9D1D9" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Change}" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#3FB950"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUp}" Value="False">
                                                            <Setter Property="Foreground" Value="#F85149"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Bakım -->
                <Border Style="{StaticResource SectionCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="&#x1F527;" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Bakım" FontSize="14" FontWeight="SemiBold" Foreground="#C9D1D9"/>
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding MaintenanceSummary}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="#8B949E" FontSize="13"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="#C9D1D9" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Change}" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#3FB950"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUp}" Value="False">
                                                            <Setter Property="Foreground" Value="#F85149"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Stok -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="&#x1F4E6;" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Stok Yönetimi" FontSize="14" FontWeight="SemiBold" Foreground="#C9D1D9"/>
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding InventorySummary}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="#8B949E" FontSize="13"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="#C9D1D9" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Change}" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#3FB950"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUp}" Value="False">
                                                            <Setter Property="Foreground" Value="#F85149"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </UniformGrid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
