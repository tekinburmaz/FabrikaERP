<UserControl x:Class="FabrikaERP.Views.Pages.PlanningPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="800" Background="#0D1117">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Planlama &amp; Kapasite Yönetimi" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>
            <UniformGrid Columns="2">
                <Border Background="#161B22" Margin="5" Padding="20" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Talep Tahminleme (AI)" Foreground="#8B949E"/>
                        <TextBlock Text="Yükleniyor..." Foreground="White" Margin="0,10"/>
                    </StackPanel>
                </Border>
                <Border Background="#161B22" Margin="5" Padding="20" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Kapasite Kullanımı (CRP)" Foreground="#8B949E"/>
                        <TextBlock Text="Analiz Ediliyor..." Foreground="White" Margin="0,10"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </Grid>
</UserControl>
