<UserControl x:Class="FabrikaERP.Views.Pages.MaintenancePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0D1117">
    <UserControl.Resources>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#21262D"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,24,24,32">

            <!-- KPI Kartları -->
            <UniformGrid Columns="4" Margin="0,0,0,24">
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Planlı Bakım" Foreground="#8B949E" FontSize="12"/>
                        <TextBlock Text="{Binding ScheduledCount}" FontSize="32" FontWeight="Bold" Foreground="#58A6FF" Margin="0,6,0,0"/>
                        <TextBlock Text="bekliyor" Foreground="#8B949E" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Devam Eden" Foreground="#8B949E" FontSize="12"/>
                        <TextBlock Text="{Binding InProgressCount}" FontSize="32" FontWeight="Bold" Foreground="#D29922" Margin="0,6,0,0"/>
                        <TextBlock Text="aktif bakım" Foreground="#8B949E" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Tamamlanan" Foreground="#8B949E" FontSize="12"/>
                        <TextBlock Text="{Binding CompletedCount}" FontSize="32" FontWeight="Bold" Foreground="#3FB950" Margin="0,6,0,0"/>
                        <TextBlock Text="bu ay" Foreground="#8B949E" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="Toplam Maliyet" Foreground="#8B949E" FontSize="12"/>
                        <TextBlock Text="{Binding TotalCost, StringFormat='₺ {0:N0}'}" FontSize="26" FontWeight="Bold" Foreground="#C9D1D9" Margin="0,6,0,0"/>
                        <TextBlock Text="bu ay" Foreground="#8B949E" FontSize="12"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Filtre -->
            <ComboBox ItemsSource="{Binding StatusOptions}"
                      SelectedItem="{Binding FilterStatus}"
                      Width="200" Height="36" HorizontalAlignment="Left"
                      Background="#161B22" Foreground="#C9D1D9"
                      BorderBrush="#30363D" FontSize="13"
                      Margin="0,0,0,16"/>

            <!-- Tablo -->
            <Border Background="#161B22" CornerRadius="12"
                    BorderThickness="1" BorderBrush="#21262D">
                <StackPanel>
                    <Border Background="#21262D" CornerRadius="12,12,0,0" Padding="20,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="TİP"       Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="AÇIKLAMA"  Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="MAKİNE"   Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="PLANLI"    Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="4" Text="TEKNİSYEN" Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="5" Text="MALİYET"   Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="6" Text="DURUM"     Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                        </Grid>
                    </Border>
                    <ItemsControl ItemsSource="{Binding Records}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#21262D" BorderThickness="0,0,0,1" Padding="20,11">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Type}"
                                                   Foreground="#58A6FF" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Title}"
                                                   Foreground="#C9D1D9" FontSize="13"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Machine.Code}"
                                                   Foreground="#8B949E" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="{Binding ScheduledAt, StringFormat='{}{0:dd MMM yyyy}'}"
                                                   Foreground="#8B949E" FontSize="13"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Technician}"
                                                   Foreground="#C9D1D9" FontSize="13"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Cost, StringFormat='₺ {0:N0}'}"
                                                   Foreground="#C9D1D9" FontSize="13"/>
                                        <TextBlock Grid.Column="6" Text="{Binding Status}"
                                                   FontSize="12" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#C9D1D9"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Scheduled">
                                                            <Setter Property="Foreground" Value="#58A6FF"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="InProgress">
                                                            <Setter Property="Foreground" Value="#D29922"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                            <Setter Property="Foreground" Value="#3FB950"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
