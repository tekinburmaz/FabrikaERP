<UserControl x:Class="FabrikaERP.Views.Pages.TradePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FabrikaERP.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000">

    <Grid Margin="20">
        <TabControl Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Bd" Background="#161B22" CornerRadius="8,8,0,0" Padding="20,10" Margin="0,0,5,0" BorderBrush="#30363D" BorderThickness="1,1,1,0" TextElement.Foreground="#8B949E">
                                    <ContentPresenter ContentSource="Header" x:Name="Content"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#1F6FEB"/>
                                        <Setter TargetName="Bd" Property="TextElement.Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- CRM (Satış) TAB -->
            <TabItem Header="Müşteriler &amp; Satış (CRM)">
                <Border Background="#0D1117" Padding="0,20,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#161B22" CornerRadius="12" BorderBrush="#30363D" BorderThickness="1">
                            <DataGrid ItemsSource="{Binding Customers}" AutoGenerateColumns="False" 
                                      Background="Transparent" BorderThickness="0" Foreground="White"
                                      RowBackground="#161B22" AlternatingRowBackground="#0D1117">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Cari Kodu" Binding="{Binding Code}" Width="100"/>
                                    <DataGridTextColumn Header="Müşteri Adı" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Şehir" Binding="{Binding City}" Width="100"/>
                                    <DataGridTextColumn Header="Risk Limit" Binding="{Binding RiskLimit, StringFormat=N0}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

            <!-- SRM (Satın Alma) TAB -->
            <TabItem Header="Tedarikçiler &amp; Alım (SRM)">
                <Border Background="#0D1117" Padding="0,20,0,0">
                    <Border Background="#161B22" CornerRadius="12" BorderBrush="#30363D" BorderThickness="1">
                        <DataGrid ItemsSource="{Binding Suppliers}" AutoGenerateColumns="False" 
                                  Background="Transparent" BorderThickness="0" Foreground="White"
                                  RowBackground="#161B22" AlternatingRowBackground="#0D1117">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tedarikçi Kodu" Binding="{Binding Code}" Width="120"/>
                                <DataGridTextColumn Header="Firma Adı" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Kategori" Binding="{Binding Category}" Width="*"/>
                                <DataGridTextColumn Header="Performans" Binding="{Binding PerformanceScore}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
