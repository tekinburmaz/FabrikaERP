<UserControl x:Class="FabrikaERP.Views.Pages.MrpPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0D1117">

    <UserControl.Resources>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#21262D"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,24,24,32">

            <!-- Başlık + MRP Çalıştır butonu -->
            <Grid Margin="0,0,0,24">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Malzeme İhtiyaç Planlaması (MRP)"
                               FontSize="16" FontWeight="SemiBold" Foreground="#C9D1D9"/>
                    <TextBlock Text="Aktif iş emirleri baz alınarak malzeme ihtiyacı hesaplanır"
                               FontSize="12" Foreground="#8B949E" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Yenile" Command="{Binding RefreshCommand}"
                            Background="#21262D" Style="{StaticResource ActionBtn}"
                            Margin="0,0,8,0"/>
                    <Button Content="MRP Hesapla" Command="{Binding RunMrpCommand}"
                            Style="{StaticResource ActionBtn}">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#1F6FEB" Offset="0"/>
                                <GradientStop Color="#00D4FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- KPI -->
            <UniformGrid Columns="3" Margin="0,0,0,24">
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Sipariş Gerekli" Foreground="#8B949E" FontSize="12"/>
                        <TextBlock Text="{Binding PendingOrderCount}" FontSize="32" FontWeight="Bold" Foreground="#F85149" Margin="0,6,0,0"/>
                        <TextBlock Text="kalem satın alım" Foreground="#8B949E" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Yetersiz Stok" Foreground="#8B949E" FontSize="12"/>
                        <TextBlock Text="{Binding ShortageCount}" FontSize="32" FontWeight="Bold" Foreground="#D29922" Margin="0,6,0,0"/>
                        <TextBlock Text="kalem açığı var" Foreground="#8B949E" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="Toplam Gereksinim" Foreground="#8B949E" FontSize="12"/>
                        <TextBlock Text="{Binding TotalRequired, StringFormat='{}{0:N0}'}" FontSize="32" FontWeight="Bold" Foreground="#58A6FF" Margin="0,6,0,0"/>
                        <TextBlock Text="birim" Foreground="#8B949E" FontSize="12"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- MRP Plan Tablosu -->
            <Border Background="#161B22" CornerRadius="12" BorderThickness="1" BorderBrush="#21262D">
                <StackPanel>
                    <Border Background="#21262D" CornerRadius="12,12,0,0" Padding="20,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="KOD"          Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="MALZEME"      Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="BİRİM"        Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="MEVCUT"       Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="4" Text="GEREKSİNİM"   Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="5" Text="SİPARİŞ MİKT." Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="6" Text="EYLEM"        Foreground="#8B949E" FontSize="11" FontWeight="SemiBold"/>
                        </Grid>
                    </Border>
                    <ItemsControl ItemsSource="{Binding PlanLines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#21262D" BorderThickness="0,0,0,1" Padding="20,11">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding MaterialCode}"
                                                   Foreground="#58A6FF" FontSize="12" FontFamily="Consolas"/>
                                        <TextBlock Grid.Column="1" Text="{Binding MaterialName}"
                                                   Foreground="#C9D1D9" FontSize="13"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Unit}"
                                                   Foreground="#8B949E" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="{Binding CurrentStock, StringFormat='{}{0:N0}'}"
                                                   FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#C9D1D9"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsShortage}" Value="True">
                                                            <Setter Property="Foreground" Value="#F85149"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Grid.Column="4" Text="{Binding RequiredQty, StringFormat='{}{0:N0}'}"
                                                   Foreground="#C9D1D9" FontSize="13"/>
                                        <TextBlock Grid.Column="5" Text="{Binding PurchaseOrderQty, StringFormat='{}{0:N0}'}"
                                                   FontSize="13" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#8B949E"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding NeedsOrder}" Value="True">
                                                            <Setter Property="Foreground" Value="#F85149"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Grid.Column="6" FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Normal"/>
                                                    <Setter Property="Foreground" Value="#3FB950"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding NeedsOrder}" Value="True">
                                                            <Setter Property="Text" Value="Sipariş Ver"/>
                                                            <Setter Property="Foreground" Value="#F85149"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
