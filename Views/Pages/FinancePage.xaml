<UserControl x:Class="FabrikaERP.Views.Pages.FinancePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FabrikaERP.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- FİNANSAL ÖZET -->
        <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,20">
            <Border Background="#161B22" CornerRadius="12" BorderBrush="#30363D" BorderThickness="1" Padding="15" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Toplam Gelir (Tahsilat)" Foreground="#8B949E" FontSize="12"/>
                    <TextBlock Text="{Binding TotalRevenue, StringFormat=N2 TRY}" Foreground="#3FB950" FontSize="22" FontWeight="Bold" Margin="0,5"/>
                </StackPanel>
            </Border>
            <Border Background="#161B22" CornerRadius="12" BorderBrush="#30363D" BorderThickness="1" Padding="15" Margin="5,0,5,0">
                <StackPanel>
                    <TextBlock Text="Toplam Gider (Ödeme)" Foreground="#8B949E" FontSize="12"/>
                    <TextBlock Text="{Binding TotalExpenses, StringFormat=N2 TRY}" Foreground="#F85149" FontSize="22" FontWeight="Bold" Margin="0,5"/>
                </StackPanel>
            </Border>
            <Border Background="#161B22" CornerRadius="12" BorderBrush="#30363D" BorderThickness="1" Padding="15" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="Bütçe Kullanım Oranı" Foreground="#8B949E" FontSize="12"/>
                    <TextBlock Text="{Binding BudgetUtilization, StringFormat={}{0:N1}%}" Foreground="#58A6FF" FontSize="22" FontWeight="Bold" Margin="0,5"/>
                    <ProgressBar Value="{Binding BudgetUtilization}" Maximum="100" Height="4" Background="#30363D" Foreground="#58A6FF" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <!-- Masraf Merkezleri -->
            <Border Grid.Column="0" Background="#161B22" CornerRadius="12" BorderBrush="#30363D" BorderThickness="1" Margin="0,0,15,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="15,12" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                        <TextBlock Text="Masraf Merkezleri &amp; Bütçe Durumu" Foreground="White" FontWeight="Bold"/>
                    </Border>
                    <DataGrid ItemsSource="{Binding CostCenters}" AutoGenerateColumns="False" 
                              Background="Transparent" BorderThickness="0" Foreground="White"
                              RowBackground="#161B22" AlternatingRowBackground="#0D1117">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Merkez" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Bütçe" Binding="{Binding Budget, StringFormat=N0}" Width="110"/>
                            <DataGridTextColumn Header="Gerçekleşen" Binding="{Binding ActualCost, StringFormat=N0}" Width="110"/>
                            <DataGridTextColumn Header="Müdür" Binding="{Binding Manager}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Son İşlemler -->
            <Border Grid.Column="1" Background="#161B22" CornerRadius="12" BorderBrush="#30363D" BorderThickness="1">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="15,12" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                        <TextBlock Text="Son Finansal İşlemler" Foreground="White" FontWeight="Bold"/>
                    </Border>
                    <ListBox ItemsSource="{Binding RecentTransactions}" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Description}" Foreground="White" FontSize="13" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding TransactionDate, StringFormat=G}" Foreground="#8B949E" FontSize="11"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Amount, StringFormat=N2}" 
                                                   Foreground="{Binding Type, Converter={StaticResource TransactionColorConverter}}"
                                                   FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
